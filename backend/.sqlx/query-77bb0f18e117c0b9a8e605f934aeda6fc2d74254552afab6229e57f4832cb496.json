  "query": "\n                SELECT t.id, t.title, t.description, t.status, t.project_id, t.assigned_to, t.created_at\n                FROM tasks t\n                INNER JOIN projects p ON t.project_id = p.id\n                WHERE t.id = $1 AND p.owner_id = $2\n            ",
